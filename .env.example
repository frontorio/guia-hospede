# String de conexão do PostgreSQL usada pelo Prisma
# Formato: postgresql://USUARIO:SENHA@HOST:PORTA/BANCO?schema=public
DATABASE_URL="postgresql://guiahospede:guiahospede@localhost:5432/guiahospede?schema=public"

# Porta em que a API HTTP irá escutar
PORT=3000

# --- Guia de experiências gerado por IA (OpenRouter) ---
# Modelo usado na geração. O prefixo "openrouter:" é opcional e ignorado.
# Dica: modelos ":free" podem ficar indisponíveis (HTTP 429); troque se preciso.
LLM_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free
# Chave da API do OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=
# Base URL da API do OpenRouter
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1